# Copernicus Climate Data Store Configuration
# Copy this file to .env and fill in your actual values.

# Required: CDS Personal Access Token
# Obtain from https://cds.climate.copernicus.eu/ -> Your Profile -> Personal Access Token
CDS_API_KEY=your_personal_access_token_here

# Optional overrides (uncomment to use):
# TAP_COPERNICUS_START_DATE=2024-01-01
# TAP_COPERNICUS_END_DATE=2024-12-31
# TAP_COPERNICUS_OUTPUT_FORMAT=netcdf
# TAP_COPERNICUS_STRICT_MODE=false
